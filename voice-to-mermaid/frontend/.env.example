# voice-to-mermaid frontend — copy to .env.local

# URL of the voice-to-mermaid backend API.
# Dev: http://localhost:7625
# Prod: your deployed backend URL (e.g. via Twingate)
NEXT_PUBLIC_API_URL=http://localhost:7625

# Server-side only — added as X-Api-Key on proxied requests.
# Must match API_KEY in backend .env. Leave blank to disable auth (dev only).
API_KEY=
